EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_SEED_DEMO_DATA=0
EXPO_PUBLIC_ENABLE_GOOGLE_AUTH=0

# Server-side only. Set this in Supabase Edge Function secrets, never in Expo:
# Do not put OPENAI_API_KEY in the Expo app.
# Set it as a Supabase Edge Function secret instead:
# supabase secrets set OPENAI_API_KEY=your_openai_key_here
