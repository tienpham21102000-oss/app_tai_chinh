{
  "name": "spendsnap",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-check.ps1",
    "doctor:fast": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-check.ps1 -SkipExpoDoctor",
    "doctor:auth": "powershell -ExecutionPolicy Bypass -File ./scripts/check-supabase-auth.ps1",
    "eas:env:preview": "eas env:list --environment preview",
    "eas:env:production": "eas env:list --environment production",
    "deploy:supabase:function": "npx supabase functions deploy ai-expense",
    "build:android:preview": "eas build -p android --profile preview",
    "build:android:production": "eas build -p android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "0.21.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
